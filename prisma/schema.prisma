// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client-js"
  //provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

//用户表
model User {
  /// 用户名（唯一，用于用户名登录）
  account  String  @unique
  /// 主键，使用 cuid
  id       String  @id @default(cuid())
  /// 姓名
  name     String
  /// 手机号（唯一，作为主要登录标识）
  phone    String  @unique
  /// 角色列表，例如：admin、leader、teacher、player 等
  roles    Role[]  @default([USER])
  /// 头像文件ID
  avatarId Int?
  /// 头像地址
  avatar   File?   @relation(fields: [avatarId], name: "avatar", references: [id])
  /// 邮箱
  email    String?
  /// 性别
  gender   String?

  /// 密码哈希（如使用 bcrypt）
  passwordHash String?
  /// 授权委托书（JSON 格式存储相关信息）
  // powerOfAttorney   Json?
  /// 创建时间
  createdAt    DateTime @default(now())
  /// 更新时间（由数据库自动更新）
  updatedAt    DateTime @updatedAt

  /// 用户订单列表
  orders    Order[]
  //用户收货地址表
  addresses UserAddress[]

  /// 保留管理员与学校负责人登录；不再关联队伍/选手
}

//用户枚举
enum Role {
  ADMIN
  USER
  //EDITOR // 可扩展更多角色
}

enum UserStatus {
  /// 待审核
  PENDING
  /// 已审核通过
  APPROVED
  /// 审核未通过
  REJECTED
  /// 已禁用
  DISABLED
}

//普通商品分类表
model ProductCategory {
  // id             String          @id @default(uuid())
  id        Int     @id @default(autoincrement())
  name      String
  /// 是否启用
  isEnabled Boolean @default(true)

  /// 商品类型
  itemType ItemType @default(PRODUCT)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Product {
  /// 主键，使用 uuid
  id            Int     @id @default(autoincrement())
  /// 商品名称
  name          String
  /// 商品简介
  description   String?
  /// 价格
  price         Int
  /// 优惠价
  discountPrice Int?

  /// 库存
  stock         Int
  /// 商品图集（列表页/轮播）
  galleryImages File[]  @relation("galleryImages")
  /// 详情图关联
  detailImages   File[]  @relation(name: "detailImages")
  /// 是否上架
  isPublished   Boolean @default(false)

  /// 分类 ID
  categoryId Int
  /// 分类关联
  category   ProductCategory @relation(fields: [categoryId], references: [id])

  // 课程详情
  courseDetail Course?

  /// 创建时间
  createdAt DateTime @default(now())
  /// 更新时间
  updatedAt DateTime @updatedAt

  // 订单项表
  orderItems OrderItem[]
}

//课程表
model Course {
  id              Int        @id @default(autoincrement())
  /// 封面图ID
  coverImageId    Int
  /// 封面图OSS地址
  coverImage      File       @relation(fields: [coverImageId], name: "coverImage", references: [id])
  /// 课程类型
  type            CourseType @default(PAID)
  /// 视频ID
  videoId         Int
  /// 完整视频OSS地址
  video           File       @relation(fields: [videoId], name: "video", references: [id])
  /// 试看时长（秒），默认5分钟
  previewDuration Int        @default(300)
  /// 视频总时长（秒）
  duration        Int?
  /// 学习人数
  studentCount    Int?       @default(0)

 /// 创建时间
  createdAt DateTime @default(now())
  /// 更新时间
  updatedAt DateTime @updatedAt

  // 添加反向关系
  productId Int?     @unique
  product   Product? @relation(fields: [productId], references: [id])
}

// 文件模型 - 系统中上传的文件信息
model File {
  id        Int       @id @default(autoincrement()) // 文件唯一标识
  fileKey   String    @unique // 文件存储键（唯一）
  fileName  String? // 原始文件名（可选）
  fileSize  Int // 文件大小（字节）
  mimeType  String // 文件MIME类型
  createdAt DateTime  @default(now()) // 创建时间
  updatedAt DateTime  @updatedAt // 更新时间
  deletedAt DateTime? // 删除时间（软删除，可选）

  meta Json? // 扩展信息

  // 关联
  avatar        User[]    @relation("avatar") //用户头像关联
  galleryImages Product[] @relation("galleryImages") //商品图集关联
  detailImages   Product[] @relation(name: "detailImages") //详情图关联
  coverImage    Course[]  @relation("coverImage") //封面图片
  video         Course[]  @relation("video") //完整视频

  @@index([fileKey])
  @@index([createdAt])
}

//课程类型枚举
enum CourseType {
  /// 免费课程
  FREE
  /// 付费课程（可试看）
  PAID
}

/// 短信验证码表：登录/注册/重置密码等场景使用
model VerificationCode {
  /// 主键，使用 cuid 生成
  id        String   @id @default(cuid())
  /// 手机号
  phone     String
  /// 验证码内容
  code      String
  /// 过期时间
  expireAt  DateTime
  /// 小时内发送次数（限流用）
  hourCount Int      @default(0)
  /// 天内发送次数（限流用）
  dayCount  Int      @default(0)
  /// 创建时间
  createdAt DateTime @default(now())

  //验证码类型
  type String @default("LOGIN")

  /// 手机号索引
  @@index([phone])
}

// 临时文件模型 - 用于存储临时上传的文件信息
model TempFile {
  id        Int      @id @default(autoincrement()) // 临时文件唯一标识
  fileKey   String // 对象存储键
  createdAt DateTime @default(now()) // 创建时间
  expiresAt DateTime // 过期时间
}

// 订单状态枚举
enum OrderStatus {
  /// 待支付
  PENDING
  /// 已支付
  PAID
  /// 已发货
  SHIPPED
  /// 已完成
  COMPLETED
  /// 已取消
  CANCELLED
  /// 已退款
  REFUNDED
}

// 订单主表
model Order {
  // id          String      @id @default(uuid())
  id Int @id @default(autoincrement())

  /// 订单编号（业务可展示的编号）
  orderNo String @unique
  /// 下单用户ID
  userId  String
  /// 关联用户
  user    User   @relation(fields: [userId], references: [id])

  /// 订单总金额
  totalAmount Int
  /// 实付金额
  payAmount   Int
  /// 订单状态
  status      OrderStatus @default(PENDING)

  /// 收货人信息
  receiverName    String
  receiverPhone   String
  receiverAddress String

  /// 支付时间
  paidAt      DateTime?
  /// 发货时间
  shippedAt   DateTime?
  /// 完成时间
  completedAt DateTime?

  /// 订单备注
  remark           String?
  /// 物流单号
  trackingNo       String?
  /// 物流公司
  logisticsCompany String?

  /// 订单项
  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// 索引优化
  @@index([userId])
  @@index([orderNo])
  @@index([status])
}

// 订单项表（一个订单包含多个商品）
model OrderItem {
  // id      String @id @default(uuid())
  id      Int   @id @default(autoincrement())
  /// 订单ID
  orderId Int
  /// 关联订单
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  itemType ItemType @default(PRODUCT)

  /// 商品ID（下单时快照）
  productId Int?     @unique
  product   Product? @relation(fields: [productId], references: [id])

  // courseId String?
  // course   Course? @relation(fields: [courseId], references: [id])

  /// 商品名称（下单时快照，防止商品后续改名；课程名称和普通商品名称统称名称）
  itemName  String
  /// 商品图片快照
  itemImage String?

  /// 购买时单价
  price    Int
  /// 购买数量
  quantity Int
  /// 该商品小计
  subtotal Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 联合唯一索引
  @@unique([orderId, productId])
}

enum ItemType {
  PRODUCT
  COURSE
}

// 用户收货地址表
model UserAddress {
  id     String @id @default(uuid())
  /// 关联用户
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// 收货人
  name     String
  /// 手机号
  phone    String
  /// 省市区
  province String
  city     String
  district String
  /// 详细地址
  detail   String

  /// 是否默认地址
  isDefault Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}
